# SwiftLint Configuration - Moderate Settings
# __PROJECT_NAME__ Project

excluded:
  - Pods
  - Carthage
  - .build
  - DerivedData
  - .swiftpm

included:
  - __PROJECT_NAME__

opt_in_rules:
  - accessibility_label_for_image
  - accessibility_trait_for_button
  - closure_spacing
  - contains_over_first_not_nil
  - direct_return
  - empty_count
  - empty_string
  - explicit_init
  - final_test_case
  - first_where
  - force_unwrapping
  - implicit_return
  - multiline_parameters
  - operator_usage_whitespace
  - redundant_nil_coalescing
  - redundant_type_annotation
  - self_binding
  - shorthand_optional_binding
  - sorted_first_last
  - sorted_imports
  - superfluous_else
  - toggle_bool
  - unhandled_throwing_task
  - type_contents_order
  - vertical_parameter_alignment_on_call

disabled_rules:
  - todo
  - trailing_whitespace

line_length:
  warning: 120
  error: 150
  ignores_comments: true
  ignores_urls: true

type_body_length:
  warning: 300
  error: 400

function_body_length:
  warning: 50
  error: 80

file_length:
  warning: 500
  error: 800
  ignore_comment_only_lines: true

identifier_name:
  min_length:
    warning: 2
    error: 1
  max_length:
    warning: 50
    error: 60
  excluded:
    - id
    - x
    - y
    - z

type_name:
  min_length: 3
  max_length: 50

cyclomatic_complexity:
  warning: 10
  error: 20

nesting:
  type_level:
    warning: 2
  function_level:
    warning: 5

force_unwrapping:
  severity: warning

type_contents_order:
  order:
    - [case]
    - [type_alias, associated_type]
    - [subtype]
    - [type_property]
    - [instance_property, initializer]
    - [deinitializer]
    - [type_method]
    - [view_life_cycle_method]
    - [other_method]
    - [subscript]

implicit_return:
  included:
    - closure
    - getter

custom_rules:
  no_print:
    name: "Print Usage"
    regex: "print\\("
    message: "Use proper logging instead of print()"
    severity: warning

reporter: "xcode"
